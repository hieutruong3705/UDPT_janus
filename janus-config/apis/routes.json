[
    {
        "name": "user-api",
        "active": true,
        "proxy": {
            "listen_path": "/users",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://user-service:9001"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        "plugins": [
            {
                "name": "rate_limit",
                "enabled": true,
                "config": {
                    "limit": "3-M",
                    "policy": "local"
                }
            }
        ]
    },
    {
        "name": "product-api",
        "active": true,
        "proxy": {
            "listen_path": "/products",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://product-service-1:9002"
                    },
                    {
                        "target": "http://product-service-2:9002"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        "plugins": [
            {
                "name": "cb",
                "enabled": true,
                "config": {
                    "timeout": 1000,
                    "error_percent_threshold": 50,
                    "request_volume_threshold": 3,
                    "sleep_window": 5000
                }
            }
        ]
    },
    {
        "name": "order-api",
        "active": true,
        "proxy": {
            "listen_path": "/orders",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://order-service-1:9003"
                    },
                    {
                        "target": "http://order-service-2:9003"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST"
            ]
        },
        "plugins": [
            {
                "name": "basic_auth",
                "enabled": true
            }
        ]
    },
    {
        "name": "product-stress-api",
        "active": true,
        "proxy": {
            "listen_path": "/products/stress",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://product-service-1:9002/stress"
                    },
                    {
                        "target": "http://product-service-2:9002/stress"
                    }
                ]
            },
            "methods": [
                "GET"
            ]
        },
        "plugins": []
    },
    {
        "name": "product-stress-one-api",
        "active": true,
        "proxy": {
            "listen_path": "/products/stress-one",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://product-service-1:9002/stress"
                    }
                ]
            },
            "methods": [
                "GET"
            ]
        },
        "plugins": []
    },
    {
        "name": "notification-api",
        "active": true,
        "proxy": {
            "listen_path": "/notifications/*",
            "strip_path": true,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://127.0.0.1:8880/notifications"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST"
            ]
        },
        "plugins": []
    }
]
