[
    {
        "name": "user-api",
        "active": true,
        "proxy": {
            "listen_path": "/users",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://user-service:9001"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        "plugins": [
            {
                "name": "rate_limit",
                "enabled": true,
                "config": {
                    "limit": "3-M",
                    "policy": "local"
                }
            }
        ]
    },
    {
        "name": "product-api",
        "active": true,
        "proxy": {
            "listen_path": "/products",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://product-service:9002"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        "plugins": [
            {
                "name": "cb",
                "enabled": true,
                "config": {
                    "timeout": 1000,
                    "error_percent_threshold": 50,
                    "request_volume_threshold": 3,
                    "sleep_window": 5000
                }
            }
        ]
    },
    {
        "name": "order-api",
        "active": true,
        "proxy": {
            "listen_path": "/orders",
            "strip_path": false,
            "upstreams": {
                "balancing": "roundrobin",
                "targets": [
                    {
                        "target": "http://order-service:9003"
                    }
                ]
            },
            "methods": [
                "GET",
                "POST"
            ]
        },
        "plugins": [
            {
                "name": "basic_auth",
                "enabled": true
            }
        ]
    }
]